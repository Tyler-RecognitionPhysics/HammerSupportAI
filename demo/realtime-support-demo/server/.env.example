# Hammer Support AI — server secrets (copy to server/.env)

OPENAI_API_KEY=sk-proj-your-key-here

# ElevenLabs Conversational AI (support agent — separate from sales)
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_AGENT_ID=agent_...
# Public HTTPS base for ElevenLabs Custom LLM (local: ngrok URL, prod: your deploy URL)
# SUPPORT_PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.dev
# SUPPORT_GREETING=Hi it's Hannah with Hammer — how can I help you today?
# ELEVENLABS_CHAT_MODEL=gpt-4o-mini

# Support admin dashboard (/admin/support)
SUPPORT_ADMIN_SECRET=your-strong-admin-password

# Slack Q&A ingest
SLACK_BOT_TOKEN=xoxb-...
SLACK_SUPPORT_CHANNEL_ID=C0123456789
# SUPPORT_SLACK_SYNTH_MODEL=gpt-4o-mini

# HubSpot Knowledge Base → support AI index
# Create a private app: https://app.hubspot.com/private-apps (scopes: content, cms.domains.read)
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-...
# Defaults match Hammer Help Center KB (https://app.hubspot.com/knowledge/3355079/206977575318/articles/state/all)
# HUBSPOT_PORTAL_ID=3355079
# HUBSPOT_KNOWLEDGE_BASE_ID=206977575318

# Optional path overrides (defaults use repo wiki-support + knowledge_support)
# SUPPORT_REPO_ROOT=C:\path\to\HAMMERFINALSITE
# SUPPORT_WIKI_DIR=
# SUPPORT_KB_DB=
# SUPPORT_RAW_DIR=
# SUPPORT_PLAYBOOK_MD=

# Chat model override
# SUPPORT_CHAT_MODEL=gpt-4o-mini

# CORS (comma-separated origins)
# SUPPORT_CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174

# Custom greeting override
# SUPPORT_GREETING=Hi, it's Hannah with Hammer. How can I help you today?
