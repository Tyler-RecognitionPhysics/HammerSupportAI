# Hammer Support AI — server secrets (copy to server/.env)

OPENAI_API_KEY=sk-proj-your-key-here

# ElevenLabs Conversational AI (support agent — separate from sales)
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_AGENT_ID=agent_...
# Public HTTPS base for ElevenLabs Custom LLM (local: ngrok URL, prod: your deploy URL)
# SUPPORT_PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.dev
# SUPPORT_GREETING=Hi it's Hannah with Hammer — how can I help you today?
# ELEVENLABS_CHAT_MODEL=gpt-4o-mini

# Support admin dashboard (/admin/support)
SUPPORT_ADMIN_SECRET=your-strong-admin-password

# Slack Q&A ingest
SLACK_BOT_TOKEN=xoxb-...
SLACK_SUPPORT_CHANNEL_ID=C0123456789
# SUPPORT_SLACK_SYNTH_MODEL=gpt-4o-mini

# HubSpot Knowledge Base + Help Desk closed tickets → support AI index
# Create a private app: https://app.hubspot.com/private-apps
# Scopes (read):
#   content, cms.domains.read, tickets, sales-email-read,
#   crm.objects.contacts.read, crm.objects.notes.read, crm.objects.emails.read,
#   crm.objects.calls.read, crm.objects.tasks.read, crm.objects.meetings.read,
#   crm.objects.communications.read, conversations.read,
#   crm.extensions_calling_transcripts.read (call transcripts)
# Scopes (write — for AI ticket creation):
#   crm.objects.contacts.write, crm.objects.tickets.write
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-...
# Comma-separated closed stage IDs (optional — auto-detected from pipelines if unset)
# HUBSPOT_CLOSED_STAGE_IDS=
# Extra ticket CRM properties to include in sync
# HUBSPOT_TICKET_PROPERTIES=
# Ticket pipeline stage IDs to exclude from AI retrieval (Hammer Spam stage shown).
# SUPPORT_EXCLUDE_TICKET_STAGE_IDS=1269291037
# Defaults match Hammer Help Center KB (https://app.hubspot.com/knowledge/3355079/206977575318/articles/state/all)
# HUBSPOT_PORTAL_ID=3355079
# HUBSPOT_KNOWLEDGE_BASE_ID=206977575318

# Master switch for ALL ticket creation (HubSpot + local DB + Slack). Set to
# 0/false to fully turn ticket creation off across the AI tool, the voice
# call-end flow, and the manual form. Defaults to enabled when unset.
# SUPPORT_ENABLE_TICKET_CREATION=0

# AI-created support tickets (pipeline/stage IDs from HubSpot → Tickets → Pipelines)
# Keep this disabled until the support site is fully live. Without this explicit
# opt-in, Hannah records tickets locally but will not create HubSpot tickets.
# SUPPORT_ENABLE_HUBSPOT_TICKET_CREATE=0
# HUBSPOT_NEW_TICKET_PIPELINE_ID=
# HUBSPOT_NEW_TICKET_STAGE_ID=
# Optional custom property name for channel source (ai_voice / ai_chat)
# HUBSPOT_TICKET_SOURCE_PROPERTY=

# Slack alert when AI creates a ticket (defaults to SLACK_SUPPORT_CHANNEL_ID)
# SUPPORT_TICKET_SLACK_CHANNEL_ID=

# ElevenLabs post-call webhook → incomplete-ticket alert (optional)
# ELEVENLABS_WEBHOOK_SECRET=
# ELEVENLABS_WEBHOOK_STRICT=0

# Automatic daily HubSpot ticket sync on the persistent host (incremental). 0/unset disables.
# Enabled by default on Fly via fly.toml. Leave unset locally to avoid surprise API calls.
# SUPPORT_AUTO_SYNC_INTERVAL_HOURS=24
# SUPPORT_AUTO_SYNC_START_DELAY_SECONDS=120

# Hard daily cap on HubSpot API usage by the support AI (covers ticket sync,
# enrichment, KB sync, ticket creation, and dashboard lookups). Counts every
# HubSpot request against a per-UTC-day budget; calls beyond the cap are blocked
# and syncs pause until the next day.
# Default cap = 25% of the 625,000/day provider limit = 156,250 calls/day.
# Set an explicit cap (overrides the fraction calculation):
# SUPPORT_HUBSPOT_DAILY_CALL_BUDGET=156250
# Or tune via fraction + provider limit:
# SUPPORT_HUBSPOT_BUDGET_FRACTION=0.25
# HUBSPOT_DAILY_API_LIMIT=625000
# Optional: path to the budget ledger SQLite (defaults next to other sync state).
# SUPPORT_HUBSPOT_BUDGET_DB=

# Persistent sync host (Fly.io) + Vercel artifact bootstrap
# Deploy Fly host: .\scripts\deploy-fly-support-sync.ps1
# Seed local KB to Fly: .\scripts\seed-fly-support-sync.ps1
# On Vercel (hammer-support-ai-final):
# SUPPORT_SYNC_HOST_URL=https://hammer-support-sync.fly.dev
# SUPPORT_KB_ARTIFACT_URL=https://hammer-support-sync.fly.dev/api/knowledge/artifact
# SUPPORT_KB_ARTIFACT_TOKEN=<same as SUPPORT_ADMIN_SECRET, or dedicated token>

# Optional path overrides (defaults use repo wiki-support + knowledge_support)
# SUPPORT_REPO_ROOT=C:\path\to\HAMMERFINALSITE
# SUPPORT_WIKI_DIR=
# SUPPORT_KB_DB=
# SUPPORT_RAW_DIR=
# SUPPORT_DATA_DIR=
# SUPPORT_PLAYBOOK_MD=

# Chat model override
# SUPPORT_CHAT_MODEL=gpt-4o-mini

# CS Questions (ticket clustering) build speed/coverage tuning
# Mine top questions ONLY from customer-initiated tickets (inbound form submissions,
# emails, chat messages, inbound calls) so Hammer-initiated work (account reviews,
# onboarding, sales/upsell, proactive outreach) is excluded. 1 (default) = on.
# Set to 0 to also include the legacy subject/timeline-snippet fallback for tickets
# with no inbound customer content (noisier, higher volume).
# CS_QUESTIONS_CUSTOMER_INITIATED_ONLY=1
# Concurrent OpenAI requests during clustering (higher = faster, mind rate limits)
# CS_QUESTIONS_CONCURRENCY=8
# Issue-snippet batch size per OpenAI map call (snippets are longer than subjects)
# CS_QUESTIONS_MAP_BATCH_SIZE=60
# Skip rare one-off subjects: 1 keeps all, 2+ only clusters subjects seen >= N times
# CS_QUESTIONS_MIN_COUNT=1
# Hard cap on unique subjects analyzed (0 = all, highest-volume first)
# CS_QUESTIONS_MAX_SUBJECTS=0
# Exclude ticket pipeline stages from CS Questions (spam/junk are auto-detected by
# label via the HubSpot pipelines API). Set explicit stage IDs here for environments
# without a live HubSpot token (e.g. serverless). Comma-separated.
# CS_QUESTIONS_EXCLUDE_STAGE_IDS=1269291037

# CORS (comma-separated origins)
# SUPPORT_CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174

# Custom greeting override
# SUPPORT_GREETING=Hi, it's Hannah with Hammer. How can I help you today?
